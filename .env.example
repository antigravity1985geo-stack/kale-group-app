# ══════════════════════════════════════════════════════════════════════
# KALE GROUP ENV CONFIG — v5.0
# ══════════════════════════════════════════════════════════════════════
# ⚠ NEVER COMMIT .env (gitignored via .gitignore → .env*).
#   Copy this file to `.env` and fill with real values.
#
# ⚠ VITE_* prefixed variables ARE exposed in the client bundle after build.
#   Only put public-safe values there (anon keys, public URLs).
#   NEVER prefix service_role keys or secrets with VITE_.
#
# ⚠ All non-VITE variables are server-only (Node/Vercel functions).
#
# ⚠ Credential rotation policy:
#   Any credential suspected leaked MUST be rotated within 24 hours.
#   Check git log --all -- .env before trusting that .env was never committed.
#
# ⚠ On Vercel: set these via Dashboard → Settings → Environment Variables
#   (NOT by committing). Separate scopes: Production / Preview / Development.
# ══════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────
# Supabase პროექტის URL (Project Settings → API)
VITE_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# Supabase anon/public key (Project Settings → API)
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Supabase service_role key — BACKEND ONLY! არასდროს client-side (Project Settings → API)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ── Google Gemini AI ──────────────────────────────────────────────────
# Google AI Studio-დან: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIzaSy..."

# ── App ───────────────────────────────────────────────────────────────
# Production URL (deploy-ის შემდეგ შეცვალეთ)
APP_URL="http://localhost:3000"
NODE_ENV="production"
ORDER_STATUS_TOKEN_SECRET="generate_with_openssl_rand_base64_48"

# ── BOG (Bank of Georgia) ─────────────────────────────────────────────
# მიიღე: businessmanager.bog.ge → API Management
BOG_CLIENT_ID="[თქვენი_კლიენტის_აიდი]"
BOG_CLIENT_SECRET="[თქვენი_გასაღები]"
BOG_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
BOG_CAMPAIGN_ID=            # განვადების კამპანიის ID (სურვილისამებრ)

# ── TBC Bank ──────────────────────────────────────────────────────────
# მიიღე: developers.tbcbank.ge → My Apps
TBC_API_KEY=
TBC_CLIENT_ID=
TBC_CLIENT_SECRET=

# ── Credo Bank ────────────────────────────────────────────────────────
# მიიღე: credobank.ge → B2B განვადება
CREDO_API_KEY=

# Comma-separated IPs allowed to POST webhook callbacks (until HMAC signatures available)
TBC_ALLOWED_IPS=
CREDO_ALLOWED_IPS=

# ── RS.GE (შემოსავლების სამსახური) ───────────────────────────────────
# მიიღე: eservices.rs.ge → ვებ-სერვისების მომხმარებელი
RS_USERNAME=                # ვებ-სერვისის მომხმარებელი (≠ ვებ-გვერდის)
RS_PASSWORD=                # ვებ-სერვისის პაროლი
RS_USER_ID=                 # ელ.დეკლარირების user_id
RS_COMPANY_ID=              # კომპანიის საიდენტიფიკაციო კოდი

# ── Cron ──────────────────────────────────────────────────────────────
# Cron secret — Vercel Cron includes this in Authorization header
CRON_SECRET=

# ── E2E Tests (Playwright) ────────────────────────────────────────────
# Supabase test user credentials — one per role (DO NOT use production accounts)
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_ACCOUNTANT_EMAIL=
E2E_ACCOUNTANT_PASSWORD=
E2E_CONSULTANT_EMAIL=
E2E_CONSULTANT_PASSWORD=

# ── Upstash Redis (Rate Limiting) ─────────────────────────────────────
# მიიღე: console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
