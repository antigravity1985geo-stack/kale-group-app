# ── Supabase ──────────────────────────────────────────────────────────
# Supabase პროექტის URL (Project Settings → API)
VITE_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# Supabase anon/public key (Project Settings → API)
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Supabase service_role key — BACKEND ONLY! არასდროს client-side (Project Settings → API)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ── Google Gemini AI ──────────────────────────────────────────────────
# Google AI Studio-დან: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIzaSy..."

# ── App ───────────────────────────────────────────────────────────────
# Production URL (deploy-ის შემდეგ შეცვალეთ)
APP_URL="http://localhost:3000"
NODE_ENV="production"

# ── BOG (Bank of Georgia) ─────────────────────────────────────────────
# მიიღე: businessmanager.bog.ge → API Management
BOG_CLIENT_ID="[თქვენი_კლიენტის_აიდი]"
BOG_CLIENT_SECRET="[თქვენი_გასაღები]"
BOG_CAMPAIGN_ID=            # განვადების კამპანიის ID (სურვილისამებრ)

# ── TBC Bank ──────────────────────────────────────────────────────────
# მიიღე: developers.tbcbank.ge → My Apps
TBC_API_KEY=
TBC_CLIENT_ID=
TBC_CLIENT_SECRET=

# ── Credo Bank ────────────────────────────────────────────────────────
# მიიღე: credobank.ge → B2B განვადება
CREDO_API_KEY=

# Comma-separated IPs allowed to POST webhook callbacks (until HMAC signatures available)
TBC_ALLOWED_IPS=
CREDO_ALLOWED_IPS=

# ── RS.GE (შემოსავლების სამსახური) ───────────────────────────────────
# მიიღე: eservices.rs.ge → ვებ-სერვისების მომხმარებელი
RS_USERNAME=                # ვებ-სერვისის მომხმარებელი (≠ ვებ-გვერდის)
RS_PASSWORD=                # ვებ-სერვისის პაროლი
RS_USER_ID=                 # ელ.დეკლარირების user_id
RS_COMPANY_ID=              # კომპანიის საიდენტიფიკაციო კოდი
